NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://nawaqare:password@localhost:5432/nawaqare_db
REDIS_URL=redis://localhost:6379

JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nawaqare-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

SMS_API_KEY=your-sms-api-key
SMS_SENDER=NawaQare

PAYMENT_WEBHOOK_SECRET=your-hmac-secret
APIX_API_KEY=your-apix-key
APIX_BASE_URL=https://payment.apix.sn

FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,https://nawacaredoctor.netlify.app

LOG_LEVEL=debug

# ─── Agora RTC (Téléconsultation vidéo) ──────────────────────────────────────
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ─── WebSocket / CORS étendu ──────────────────────────────────────────────────
SOCKET_CORS_ORIGINS=http://localhost:3001,https://nawacaredoctor.netlify.app

# ─── Comptes admin (seed) ─────────────────────────────────────────────────────
ADMIN_PHONE=+221700000000
SUPER_ADMIN_PHONE=+221700000001

# ─── Rate limiting ────────────────────────────────────────────────────────────
OTP_MAX_ATTEMPTS=5
OTP_TTL_SECONDS=300
LOGIN_LOCKOUT_ATTEMPTS=5
